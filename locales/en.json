  "about": {
    "title": "About Joyride",
    "subtitle": "We're on a mission to bring premium therapeutic toys to every household in Saudi Arabia, making quality accessible and affordable.",
    "storyTitle": "Our Story",
    "storyP1": "Founded in 2020, Joyride started with a simple idea: everyone deserves access to quality therapeutic toys without breaking the bank.",
    "storyP2": "What began as a small online store has grown into one of Saudi Arabia's leading e-commerce platforms for therapeutic toys, serving thousands of customers across the country.",
    "storyP3": "Today, we partner with over 100 trusted brands to bring you a curated selection of sensory toys, motor skills kits, small toys, and cognitive development games.",
